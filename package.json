{
  "name": "@onecoach/one-agent-hooks",
  "version": "0.1.0",
  "description": "React hooks for OneAgent SDK 4.1 - streaming, progress, admin mode",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@onecoach/one-agent": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/onecoach/onecoach.git",
    "directory": "submodules/one-agent-hooks"
  },
  "keywords": [
    "oneagent",
    "react-hooks",
    "streaming",
    "ai-agents",
    "vercel-ai-sdk",
    "workflow-devkit"
  ],
  "license": "MIT"
}
